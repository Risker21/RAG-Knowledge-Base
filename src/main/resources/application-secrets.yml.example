# 将本文件复制为 application-secrets.yml 并填入实际值
# 注意：application-secrets.yml 已被 .gitignore 忽略，不会提交到仓库
spring:
  datasource:
    password: your_db_password_here

app:
  openai:
    api-key: your_openai_api_key_here
  stt:
    app-id: your_volcengine_app_id_here
    access-token: your_volcengine_access_token_here
